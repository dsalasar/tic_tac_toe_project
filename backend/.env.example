# ──────────────────────────────────────────────
# Tic Tac Toe — Backend Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────
PORT=3000

# Allow requests from the frontend origin (use * for any)
CORS_ORIGIN=*

# ── Database Selection ───────────────────────────────────
# Choose one: mongodb | mysql
DB_TYPE=mongodb

# ── MongoDB (used when DB_TYPE=mongodb) ──────────────────
# Local default
MONGO_URI=mongodb://localhost:27017/tictactoe

# Atlas example (replace with your cluster URI)
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/tictactoe?retryWrites=true&w=majority

# ── MySQL (used when DB_TYPE=mysql) ──────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DB=tictactoe
